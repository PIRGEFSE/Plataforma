# =============================================================
# PIRGEFSE — Variables de entorno para PRODUCCIÓN
# Servidor: 192.141.169.15 | Dominio: pirgefse.cl
# =============================================================
# INSTRUCCIONES:
#   1. Copiar como .env.production en el servidor:
#        cp .env.production.template .env.production
#   2. Rellenar TODOS los valores <CAMBIAR_...>
#   3. NUNCA subir .env.production al repositorio git
#   4. Permisos: chmod 600 .env.production
#
# Generar contraseñas:
#   openssl rand -base64 32
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# =============================================================

# --- Base de datos (superusuario — solo para administración) ---
POSTGRES_DB=pirgefse_db
POSTGRES_USER=pirgefse
# Generar con: openssl rand -base64 32
POSTGRES_PASSWORD=<CAMBIAR_CONTRASEÑA_FUERTE_ALEATORIA>

# --- Usuario de aplicación (el que usa el backend) ---
# Este usuario NO tiene superuser — permisos mínimos necesarios
POSTGRES_APP_USER=pirgefse_app
# Generar con: openssl rand -base64 32
POSTGRES_APP_PASSWORD=<CAMBIAR_CONTRASEÑA_APP_ALEATORIA>

# --- JWT (backend) ---
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
# DEBE tener al menos 64 caracteres
SECRET_KEY=<CAMBIAR_SECRET_KEY_64_CHARS_MINIMO>

# --- CORS (backend) ---
# Dominio de producción del frontend
FRONTEND_URL=https://pirgefse.cl
